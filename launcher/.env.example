# Copie ce fichier vers .env (jamais commité) et renseigne les valeurs.
# Voir README.md > "Configuration" pour le détail de chaque variable.

# Client ID de l'application Azure AD utilisée pour la connexion Microsoft (obligatoire).
MAIN_VITE_AZURE_CLIENT_ID=

# owner/repo GitHub où sont publiées les releases du modpack (mods + pack-manifest.json).
MAIN_VITE_MODPACK_REPO=goilardkillian-boop/lycania-files

# owner/repo GitHub où sont publiées les releases du launcher (auto-update).
MAIN_VITE_LAUNCHER_REPO=goilardkillian-boop/Lycania
